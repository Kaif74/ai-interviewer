# Server
PORT=5000

# LLM (Groq — same key as STT, no separate key needed)
# Available models: openai/gpt-oss-120b | openai/gpt-oss-20b | meta-llama/llama-4-scout-17b-16e-instruct
LLM_MODEL=openai/gpt-oss-120b

# Speech-to-Text (Groq — also used for LLM above)
GROQ_API_KEY=your_groq_api_key_here

# Text-to-Speech (Mistral Voxtral TTS)
MISTRAL_API_KEY=your_mistral_api_key_here
